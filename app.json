{
  "expo": {
    "name": "GymSmart",
    "slug": "GymSmart",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Icono.png",
    "scheme": "gymsmart",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/Icono.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/Icono.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/Icono.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-sqlite",
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
